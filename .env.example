# Copy to .env.local and fill in. For LOCAL dev, get the values from `supabase status`
# (or `supabase status -o env`). The local demo keys are non-secret and the same on every
# machine. For a hosted project, copy from the Supabase dashboard → Project Settings → API.

# Browser-safe (sent to the client). The anon/publishable key is protected by RLS.
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<local anon key from `supabase status`>"

# Server-only. NEVER prefix with NEXT_PUBLIC_ and never commit a real value.
SUPABASE_SERVICE_ROLE_KEY="<local service_role key from `supabase status`>"
